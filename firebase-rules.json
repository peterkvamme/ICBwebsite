{
  "rules": {
    "boat": {
      "current": {
        ".read": true,
        ".write": "auth != null && root.child('captains').child(auth.uid).val() === true",
        "lat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
        "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
        "accuracy": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "headline": { ".validate": "newData.isString() && newData.val().length <= 80" },
        "status": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "note": { ".validate": "newData.isString() && newData.val().length <= 160" },
        "availableAt": { ".validate": "newData.val() === null || newData.isString()" },
        "pauseUntil": { ".validate": "newData.val() === null || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },
    "captains": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}
